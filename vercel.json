{
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/verify",
      "dest": "api/main.py"
    },
    {
      "src": "/api/fix-refs",
      "dest": "api/main.py"
    },
    {
      "src": "/",
      "dest": "public/index.html"
    }
  ]
}
